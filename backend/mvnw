#!/usr/bin/env sh
BASE_DIR="$(cd "$(dirname "$0")" && pwd)"
MAVEN_DIR="$BASE_DIR/.mvn/apache-maven-3.9.12"
MAVEN_ZIP="$BASE_DIR/.mvn/apache-maven-3.9.12-bin.zip"

if [ ! -x "$MAVEN_DIR/bin/mvn" ]; then
  if [ ! -f "$MAVEN_ZIP" ]; then
    echo "Maven zip not found: $MAVEN_ZIP" >&2
    exit 1
  fi
  if command -v unzip >/dev/null 2>&1; then
    unzip -q -o "$MAVEN_ZIP" -d "$BASE_DIR/.mvn"
  else
    echo "unzip is not available" >&2
    exit 1
  fi
fi

exec "$MAVEN_DIR/bin/mvn" "$@"
